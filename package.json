{
  "name": "obsidian-vault-chat",
  "version": "0.4.0",
  "description": "Obsidian RAG chat plugin - ask questions answered by your vault notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "rag",
    "chat",
    "vault",
    "embeddings"
  ],
  "author": "eohjun",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.2",
    "obsidian": "^1.11.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "obsidian-llm-shared": "github:eohjun/obsidian-llm-shared"
  }
}
